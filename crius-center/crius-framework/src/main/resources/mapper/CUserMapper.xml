<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.pbkj.crius.mapper.CUserMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.pbkj.crius.entity.po.CUser">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="age" property="age"/>
        <result column="created_time" property="createdTime"/>
        <result column="created_by" property="createdBy"/>
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, username, age, created_time, created_by
    </sql>
    <select id="selectCursorList" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM c_user
        WHERE id &lt; #{cursor} ORDER BY id DESC LIMIT #{size}
    </select>

</mapper>
